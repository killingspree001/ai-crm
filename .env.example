# Database (PostgreSQL) — e.g. a free Neon database
DATABASE_URL="postgresql://user:password@host:5432/ai_crm?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# AI provider (optional — features run on mock data unless this is set)
# AI_PROVIDER can be "mock" (default), "openai", or "anthropic"
AI_PROVIDER="mock"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
