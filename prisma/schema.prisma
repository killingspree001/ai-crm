// AI CRM — Prisma schema
// Postgres via driver adapter (Prisma 7). Connection URL is provided at runtime
// through @prisma/adapter-pg, and for CLI commands via prisma.config.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SALES_REP
  VIEWER
}

enum DealStage {
  LEAD
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum DealHealth {
  HEALTHY
  AT_RISK
  STALLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ActivityType {
  NOTE
  EMAIL
  CALL
  MEETING
  STAGE_CHANGE
  TASK
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String?  @unique
  password  String?
  image     String?
  role      UserRole @default(SALES_REP)

  contacts   Contact[]
  deals      Deal[]
  tasks      Task[]      @relation("TaskAssignee")
  activities Activity[]
  meetings   Meeting[]
  accounts   Account[]
  sessions   Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id      String   @id @default(cuid())
  name    String
  email   String?
  phone   String?
  company String?
  title   String?
  tags    String[] @default([])
  notes   String?  @db.Text

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  deals      Deal[]
  tasks      Task[]
  activities Activity[]
  meetings   Meeting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Deal {
  id                String     @id @default(cuid())
  title             String
  value             Int        @default(0) // in whole currency units
  stage             DealStage  @default(LEAD)
  health            DealHealth @default(HEALTHY)
  probability       Int        @default(20) // 0-100, AI-scored
  expectedCloseDate DateTime?
  position          Int        @default(0) // ordering within a Kanban column

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  tasks      Task[]
  activities Activity[]
  files      DealFile[]
  meetings   Meeting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([stage])
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  aiGenerated Boolean      @default(false)

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assigneeId])
  @@index([status])
}

model Meeting {
  id         String   @id @default(cuid())
  title      String
  transcript String   @db.Text
  summary    String?  @db.Text
  occurredAt DateTime @default(now())
  processed  Boolean  @default(false)

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([ownerId])
}

model Activity {
  id      String       @id @default(cuid())
  type    ActivityType @default(NOTE)
  content String       @db.Text

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([contactId])
  @@index([dealId])
}

model DealFile {
  id        String   @id @default(cuid())
  name      String
  url       String
  size      Int      @default(0)
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([dealId])
}

// --- NextAuth models ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
